# ========== KẾT NỐI – Copy thành .env khi deploy VPS / chạy máy ==========
# cp .env.example .env

# Binance: CHỈ LẤY GIÁ từ API công khai (https://fapi.binance.com) – không cần bật profile/API key.
# Paper trade chạy trên code (VPS/máy), không dùng chương trình paper trade của Binance.
# Chỉ điền key khi sau này bật trade thật (đặt lệnh trên sàn).
BINANCE_API_KEY=
BINANCE_API_SECRET=

